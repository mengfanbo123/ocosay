{
  "name": "@mingxy/ocosay",
  "version": "1.1.17",
  "description": "OpenCode TTS 播放插件 - 支持豆包模式边接收边朗读",
  "type": "module",
  "main": "dist/plugin.js",
  "types": "dist/plugin.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/mengfanbo123/ocosay.git"
  },
  "homepage": "https://github.com/mengfanbo123/ocosay#readme",
  "exports": {
    ".": {
      "import": "./dist/plugin.js",
      "types": "./dist/plugin.d.ts"
    },
    "./plugin": {
      "import": "./dist/plugin.js",
      "types": "./dist/plugin.d.ts"
    },
    "./lib": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && npm run build:plugin && node -e \"require('fs').copyFileSync('package.json', 'dist/package.json')\"",
    "build:plugin": "esbuild src/plugin.ts --bundle --platform=node --format=esm --outdir=dist --sourcemap --external:@opencode-ai/plugin --external:axios --external:ws --external:zod --external:naudiodon --external:play-sound --external:speaker",
    "watch": "tsc --watch",
    "test": "jest",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "tts",
    "text-to-speech",
    "opencode",
    "plugin"
  ],
  "author": "mingxy",
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "^1.3.15",
    "axios": "^1.6.0",
    "howler": "^2.2.4",
    "pino": "^10.3.1",
    "ws": "^8.14.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "naudiodon": "^2.3.6"
  },
  "devDependencies": {
    "@types/howler": "^2.2.12",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "esbuild": "^0.28.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
